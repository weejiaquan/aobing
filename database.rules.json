{
  "rules": {
    "clicks": {
      ".read": true,
      ".write": true,
      ".validate": "newData.isNumber() && newData.val() >= (data.exists() ? data.val() : 0) && newData.val() <= (data.exists() ? data.val() : 0) + 100000"
    },
    "clicks_by_source": {
      ".read": true,
      "$source": {
        ".write": true,
        ".validate": "newData.isNumber() && ($source === 'mouse' || $source === 'keyboard' || $source === 'auto') && newData.val() >= (data.exists() ? data.val() : 0) && newData.val() <= (data.exists() ? data.val() : 0) + 100000"
      }
    },
    "skins": {
      ".read": true,
      "$variantId": {
        ".write": true,
        ".validate": "newData.isNumber() && $variantId.length <= 20 && newData.val() >= (data.exists() ? data.val() : 0) && newData.val() <= (data.exists() ? data.val() : 0) + 100000"
      }
    },
    "combo": {
      ".read": true,
      "allTime": {
        ".write": true,
        ".validate": "newData.isNumber() && newData.val() >= (data.exists() ? data.val() : 0)"
      }
    },
    "daily": {
      ".read": true,
      "$date": {
        "total": {
          ".write": true,
          ".validate": "newData.isNumber() && newData.val() >= (data.exists() ? data.val() : 0) && newData.val() <= (data.exists() ? data.val() : 0) + 100000"
        },
        "countries": {
          "$country": {
            ".write": true,
            ".validate": "newData.isNumber() && $country.length == 2 && newData.val() >= (data.exists() ? data.val() : 0) && newData.val() <= (data.exists() ? data.val() : 0) + 100000"
          }
        },
        "skins": {
          "$skinId": {
            ".write": true,
            ".validate": "newData.isNumber() && $skinId.length <= 20 && newData.val() >= (data.exists() ? data.val() : 0) && newData.val() <= (data.exists() ? data.val() : 0) + 100000"
          }
        },
        "characters": {
          "$characterId": {
            ".write": true,
            ".validate": "newData.isNumber() && $characterId.length <= 20 && newData.val() >= (data.exists() ? data.val() : 0) && newData.val() <= (data.exists() ? data.val() : 0) + 100000"
          }
        },
        "maxCombo": {
          ".write": true,
          ".validate": "newData.isNumber() && newData.val() >= (data.exists() ? data.val() : 0)"
        },
        "visitors": {
          "$visitorId": {
            ".write": true,
            ".validate": "newData.isBoolean() && $visitorId.length <= 64"
          }
        },
        "sources": {
          "$source": {
            ".write": true,
            ".validate": "newData.isNumber() && ($source === 'mouse' || $source === 'keyboard' || $source === 'auto') && newData.val() >= (data.exists() ? data.val() : 0) && newData.val() <= (data.exists() ? data.val() : 0) + 100000"
          }
        }
      }
    },
    "kei": {
      ".read": true,
      "completions":          { ".write": true, ".validate": "newData.isNumber() && newData.val() >= (data.exists() ? data.val() : 0) && newData.val() <= (data.exists() ? data.val() : 0) + 100000" },
      "totalHeadpatSeconds":  { ".write": true, ".validate": "newData.isNumber() && newData.val() >= (data.exists() ? data.val() : 0) && newData.val() <= (data.exists() ? data.val() : 0) + 100000" },
      "totalVoicelines":      { ".write": true, ".validate": "newData.isNumber() && newData.val() >= (data.exists() ? data.val() : 0) && newData.val() <= (data.exists() ? data.val() : 0) + 100000" },
      "totalInteractions":    { ".write": true, ".validate": "newData.isNumber() && newData.val() >= (data.exists() ? data.val() : 0) && newData.val() <= (data.exists() ? data.val() : 0) + 100000" },
      "totalPinches":         { ".write": true, ".validate": "newData.isNumber() && newData.val() >= (data.exists() ? data.val() : 0) && newData.val() <= (data.exists() ? data.val() : 0) + 100000" },
      "totalEyeTracks":       { ".write": true, ".validate": "newData.isNumber() && newData.val() >= (data.exists() ? data.val() : 0) && newData.val() <= (data.exists() ? data.val() : 0) + 100000" }
    },
    "users": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "profile": {
          "displayName": { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 24" },
          "country":     { ".validate": "newData.isString() && newData.val().length === 2" },
          "photoURL":    { ".validate": "newData.isString() && newData.val().length <= 500" },
          "provider":    { ".validate": "newData.isString() && newData.val().length <= 32" },
          "linkedAt":    { ".validate": "newData.isNumber()" }
        },
        "stats": {
          "totalClicks": {
            ".validate": "newData.isNumber() && newData.val() >= (data.exists() ? data.val() : 0) + 1 && newData.val() <= (data.exists() ? data.val() : 0) + 10000 && now - (data.parent().child('lastClickAt').exists() ? data.parent().child('lastClickAt').val() : 0) >= 1000 && newData.parent().child('lastClickAt').val() === now"
          },
          "coinBalance": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= (data.exists() ? data.val() : 0) + 10000"
          },
          "lastClickAt": {
            ".validate": "newData.val() === now"
          },
          "maxCombo":  { ".validate": "newData.isNumber()" },
          "createdAt": { ".validate": "newData.isNumber()" },
          "prestigeStars": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= (data.exists() ? data.val() : 0) + 1"
          },
          "skins": {
            "$variantId": {
              ".validate": "newData.isNumber() && $variantId.length <= 20"
            }
          },
          "bonds": {
            "$variantId": {
              ".validate": "newData.isNumber() && $variantId.length <= 20 && newData.val() >= 0 && newData.val() <= (data.exists() ? data.val() : 0) + 1 && newData.val() <= 10"
            }
          },
          "bySource": {
            "$source": {
              ".validate": "newData.isNumber() && ($source === 'mouse' || $source === 'keyboard' || $source === 'auto') && newData.val() >= (data.exists() ? data.val() : 0) + 1 && newData.val() <= (data.exists() ? data.val() : 0) + 10000 && now - (data.parent().parent().child('lastClickAt').exists() ? data.parent().parent().child('lastClickAt').val() : 0) >= 1000 && newData.parent().parent().child('lastClickAt').val() === now"
            }
          }
        },
        "shop": {
          "coinMulLevel":            { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 30" },
          "clickMulLevel":           { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 30" },
          "autoLevel":               { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 30" },
          "leaderboardAutoUnlocked": { ".validate": "newData.isBoolean()" },
          "buffs": {
            "$kind": {
              ".validate": "$kind === 'coins' || $kind === 'clicks' || $kind === 'autoRate'",
              "expiresAt": { ".validate": "newData.isNumber() && newData.val() <= now + 3600000" }
            }
          }
        }
      }
    },
    "admins": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && root.child('admins').child(auth.uid).val() === true",
        ".validate": "newData.isBoolean()"
      }
    },
    "leaderboard": {
      "topClicks": {
        ".read": true,
        ".indexOn": "totalClicks",
        "$uid": {
          ".write": "(auth != null && auth.uid === $uid && root.child('users').child($uid).child('profile').exists() && auth.token.firebase.identities['google.com'] != null) || (auth != null && root.child('admins').child(auth.uid).val() === true)",
          "name":        { ".validate": "newData.isString() && newData.val().length <= 24 && (root.child('admins').child(auth.uid).val() === true || newData.val() === root.child('users').child($uid).child('profile').child('displayName').val())" },
          "country":     { ".validate": "newData.isString() && newData.val().length === 2 && (root.child('admins').child(auth.uid).val() === true || newData.val() === root.child('users').child($uid).child('profile').child('country').val())" },
          "photoURL":    { ".validate": "newData.isString() && newData.val().length <= 500 && (root.child('admins').child(auth.uid).val() === true || newData.val() === (root.child('users').child($uid).child('profile').child('photoURL').exists() ? root.child('users').child($uid).child('profile').child('photoURL').val() : ''))" },
          "totalClicks": { ".validate": "newData.isNumber() && (root.child('admins').child(auth.uid).val() === true || newData.val() <= (root.child('users').child($uid).child('stats').child('totalClicks').exists() ? root.child('users').child($uid).child('stats').child('totalClicks').val() : 0))" },
          "level":       { ".validate": "newData.isNumber()" },
          "hidden":      { ".validate": "newData.isBoolean() && root.child('admins').child(auth.uid).val() === true" }
        }
      }
    },
    ".read": false,
    ".write": false
  }
}
