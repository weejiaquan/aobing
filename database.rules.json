{
  "rules": {
    "clicks": {
      ".read": true,
      ".write": true,
      ".validate": "newData.isNumber()"
    },
    "skins": {
      ".read": true,
      "$variantId": {
        ".write": true,
        ".validate": "newData.isNumber() && $variantId.length <= 20"
      }
    },
    "combo": {
      ".read": true,
      "allTime": {
        ".write": true,
        ".validate": "newData.isNumber()"
      }
    },
    "daily": {
      ".read": true,
      "$date": {
        "total": {
          ".write": true,
          ".validate": "newData.isNumber()"
        },
        "countries": {
          "$country": {
            ".write": true,
            ".validate": "newData.isNumber() && $country.length == 2"
          }
        },
        "skins": {
          "$skinId": {
            ".write": true,
            ".validate": "newData.isNumber() && $skinId.length <= 20"
          }
        },
        "characters": {
          "$characterId": {
            ".write": true,
            ".validate": "newData.isNumber() && $characterId.length <= 20"
          }
        },
        "maxCombo": {
          ".write": true,
          ".validate": "newData.isNumber()"
        },
        "visitors": {
          "$visitorId": {
            ".write": true,
            ".validate": "newData.isBoolean() && $visitorId.length <= 64"
          }
        }
      }
    },
    "kei": {
      ".read": true,
      "completions": {
        ".write": true,
        ".validate": "newData.isNumber()"
      },
      "totalHeadpatSeconds": {
        ".write": true,
        ".validate": "newData.isNumber()"
      },
      "totalVoicelines": {
        ".write": true,
        ".validate": "newData.isNumber()"
      },
      "totalInteractions": {
        ".write": true,
        ".validate": "newData.isNumber()"
      },
      "totalPinches": {
        ".write": true,
        ".validate": "newData.isNumber()"
      },
      "totalEyeTracks": {
        ".write": true,
        ".validate": "newData.isNumber()"
      }
    },
    ".read": false,
    ".write": false
  }
}